# ─────────────────────────────────────────────────────────────────────────────
# Supabase — created in phase 2 (you create the dev project, paste values here).
#
# Naming convention uses Supabase's NEW API key system (rolled out 2025):
#   • sb_publishable_*  replaces the old `anon` key  (safe to ship to browser)
#   • sb_secret_*       replaces the old `service_role` key  (server only)
# Legacy anon/service_role keys still work through end of 2026 but cannot be
# rotated — migrate now. https://supabase.com/docs/guides/api/api-keys
# ─────────────────────────────────────────────────────────────────────────────

# Naming follows Supabase's official Drizzle/Prisma convention:
#   • DATABASE_URL → shared transaction-mode pooler (port 6543, IPv4)
#       Used by /api/* routes and anything in the serverless runtime.
#       prepare:false is set in code per A1 (PgBouncer in tx-mode can't reuse
#       prepared statements between requests).
#   • DIRECT_URL → shared session-mode pooler (port 5432, IPv4)
#       Used by migrations, build-time RSC reads, scripts/migrate-wp.ts.
#       Session mode preserves prepared statements and supports DDL.
# Both URLs use the pooler (not the direct db.<ref>.supabase.co endpoint)
# because Supabase free-tier direct is IPv6-only and Vercel serverless is
# IPv4-only — they can't talk. Pooler endpoints are IPv4 on both modes.
# Grab both from Supabase Dashboard → Connect → ORM tab (Prisma view shows
# both at once) or the Direct tab with the dropdown set to each pooler mode.
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-N-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-N-[YOUR-REGION].pooler.supabase.com:5432/postgres

# Supabase project base URL — used to construct Storage public URLs.
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# NEW API key system.
# Publishable (sb_publishable_*) — safe in browser, equivalent of the old anon key.
# Find at: Supabase Dashboard → Settings → API Keys → Publishable
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret (sb_secret_*) — server only, equivalent of the old service_role key.
# Find at: Supabase Dashboard → Settings → API Keys → Secret keys → Reveal
SUPABASE_SECRET_KEY=sb_secret_...

# ─────────────────────────────────────────────────────────────────────────────
# Phase 9 — runtime API + admin tooling. All three required at boot.
# ─────────────────────────────────────────────────────────────────────────────

# /api/revalidate bearer. Same value in every Supabase Webhook's
# `Authorization: Bearer <value>` header. Rotate annually or on leak.
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=

# HMAC signing key for the /admin/* session cookie. Rotating this value
# invalidates every active admin session (kill-switch for "I lost my laptop").
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Owner login password. Typed at /admin/login. Memorable but non-trivial.
# Compared via timingSafeEqual; failed attempts get a 1s constant-time delay.
ADMIN_PASSWORD=

# Future:
# GA4_MEASUREMENT_ID=            # phase 10 analytics per D16
