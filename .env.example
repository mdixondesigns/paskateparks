# Supabase — populated in phase 2 (you create the dev project, paste values here).
# Direct connection (port 5432) — for build-time RSC reads, migrations, the migrate-wp.ts script.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Pooled connection (port 6543) — for /api/* routes and anything in serverless runtime.
# MUST include ?pgbouncer=true; the pooled Drizzle client also sets prepare:false per A1.
DATABASE_POOL_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase API keys — anon is safe in the browser, service-role is god-mode (server only).
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# /api/revalidate bearer (phase 9). Generate with: openssl rand -hex 32
REVALIDATE_SECRET=

# Future (phase 9+):
# ADMIN_TOKEN=                   # bearer for /admin/lint
# GA4_MEASUREMENT_ID=            # phase 10 analytics per D16
