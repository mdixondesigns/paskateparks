{
  "name": "paskateparks",
  "version": "0.1.0",
  "private": true,
  "description": "Pennsylvania Skateparks directory — Next.js 16 + Supabase + Drizzle rebuild of paskateparks.com",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:migrate:dry-run": "tsx scripts/db-migrate.ts --dry-run",
    "db:verify": "tsx scripts/db-verify.ts",
    "db:check-coords": "tsx scripts/check-park-coords.ts",
    "db:seed-fdr": "tsx scripts/db-seed-fdr.ts",
    "db:studio": "drizzle-kit studio",
    "migrate-wp": "tsx scripts/migrate-wp.ts",
    "migrate-wp:dry-run": "tsx scripts/migrate-wp.ts --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.7",
    "php-serialize": "^5.1.3",
    "postgres": "^3.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.7",
    "happy-dom": "^16.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "supabase": "^2.104.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
